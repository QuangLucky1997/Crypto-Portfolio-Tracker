<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/viewToken"
    android:background="?attr/appBackground"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/_5sdp">

    <!-- Icon -->
    <ImageView
        android:id="@+id/iconToken"
        android:layout_width="@dimen/_30sdp"
        android:layout_height="@dimen/_30sdp"
        android:src="@drawable/coin"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"/>

    <!-- Tên + Market Cap -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/iconToken"
        android:layout_marginStart="@dimen/_8sdp"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/nameToken"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BTC"
            android:textSize="@dimen/_12ssp"
            android:fontFamily="@font/inter_bold"
            android:textColor="?attr/textPrimary"/>

        <TextView
            android:id="@+id/marketCapitalizationToken"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$521,49B"
            android:textSize="@dimen/_10ssp"
            android:fontFamily="@font/inter_medium"
            android:textColor="?attr/textPrimary"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/priceLayout"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/priceToken"
            android:layout_width="@dimen/_80sdp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="$111,314.05"
            android:textSize="@dimen/_12ssp"
            android:fontFamily="@font/inter_bold"
            android:textColor="?attr/textPrimary"
            android:singleLine="true"
            android:ellipsize="end"/>


        <androidx.cardview.widget.CardView
            android:id="@+id/cardPercent24H"
            android:layout_width="@dimen/_60sdp"
            android:layout_height="@dimen/_25sdp"
            android:layout_marginEnd="@dimen/_8sdp"
            app:cardBackgroundColor="@color/green"
            app:cardCornerRadius="@dimen/_8sdp"
            android:layout_marginStart="12dp"
            android:layout_gravity="center_vertical"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="@dimen/_4sdp"
                android:paddingEnd="@dimen/_4sdp">

                <TextView
                    android:id="@+id/percentRealtime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_2sdp"
                    android:ellipsize="none"
                    android:fontFamily="@font/inter_bold"
                    android:maxLines="1"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_11ssp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</RelativeLayout>
